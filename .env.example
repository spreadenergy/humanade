# PostgreSQL connection string.
# - On Vercel: created automatically when you add a Neon database (Storage tab).
# - Local development: postgresql://humanade:humanade@localhost:5432/humanade
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret key for the /admin moderation page — set your own long random value.
# Admin stays disabled while this is unset or left as "change-me".
ADMIN_KEY="change-me"

# Public site URL (used in management links, sitemap, metadata).
# For a temporary deployment, set it to that deployment's URL.
NEXT_PUBLIC_SITE_URL="https://humanade.org"

# ---------------------------------------------------------------------------
# WhatsApp bot (optional) — lets people post by sending a WhatsApp message.
# See the "WhatsApp bot" section of the README for full setup instructions.
# ---------------------------------------------------------------------------
# Shown on the /post page as a "Post via WhatsApp" button (with country code;
# non-digits are stripped automatically).
# NEXT_PUBLIC_WHATSAPP_NUMBER="+58 412 000 0000"
# A random string you invent; paste the same value in Meta's webhook config.
# WHATSAPP_VERIFY_TOKEN=""
# Permanent access token from your Meta app (System User token).
# WHATSAPP_ACCESS_TOKEN=""
# Phone number ID from WhatsApp > API Setup in the Meta app dashboard.
# WHATSAPP_PHONE_NUMBER_ID=""
# App secret from Meta App Settings > Basic. Enables webhook signature checks.
# WHATSAPP_APP_SECRET=""
