generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id          String   @id @default(cuid())
  type        String // NEED | OFFER
  title       String
  description String
  category    String // CONNECT | HEALTH | DENTAL | NUTRITION | SHELTER | VOLUNTEERS | LOGISTICS | EDUCATION
  urgency     String   @default("NORMAL") // CRITICAL | HIGH | NORMAL
  status      String   @default("OPEN") // OPEN | ASSIGNED | FULFILLED | CLOSED
  quantity    String?
  locationName String
  lat         Float?
  lng         Float?
  contactName String
  orgName     String?
  phone       String?
  whatsapp    String?
  email       String?
  manageToken String   @unique
  hidden      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reports     Report[]

  @@index([type, status, category, urgency])
  @@index([createdAt])
}

model Report {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reason    String // SPAM | FALSE | OFFENSIVE | SCAM | OTHER
  comment   String?
  createdAt DateTime @default(now())

  @@index([listingId])
}
